---
const { name, image, favorite_emoji, github_permalink, github_profile, codepen_profile } = Astro.props;
const slug = name.toLowerCase().replace(/\s+/g, "-");
---

<figure class="card">
  <img src={image} alt={name} loading="lazy" />
  <figcaption class="card-name">
    <a href={`/${slug}`}><span class="card-emoji">{favorite_emoji}</span> {name}</a>
  </figcaption>
  <nav class="card-links">
    <a href={github_permalink} target="_blank" rel="noopener">Portfolio</a>
    <a href={github_profile} target="_blank" rel="noopener">GitHub</a>
    <a href={codepen_profile} target="_blank" rel="noopener">CodePen</a>
  </nav>
</figure>



<style>
  .card {
    background: #202222;
    border: 0;
    /* padding: 1rem; */
    display: flex;
    flex-direction: row;
    gap: 1rem;
    border: 1px solid lightgray;
      border-radius: 12px 0 0 12px;
     transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .card img {
    width: 50%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
      border-radius: 12px 0 0 12px;
    
  }

a {

}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

  .card-name {
    }

  .card-emoji {
  
  }

  .card-links {
    display: flex;
    gap: 0.75rem;
    margin-top: auto;
  }

  .card-links a {
    text-decoration: none;
    color: goldenrod;
    border-bottom: 1px solid currentColor;
  }

  .card-links a:hover {
    background: gray;
    color: white;
  }
</style>
