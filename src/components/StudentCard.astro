---
const { name, image, favorite_emoji, github_permalink, github_profile, codepen_profile } = Astro.props;
const slug = name.toLowerCase().replace(/\s+/g, "-");

const cardColors = [
  "#263238",
  "#2f3e46",
  "#3a405a",
  "#4a3f35",
  "#314d44",
  "#433b57",
  "#36454f",
  "#2d3a3a",
];

const colorIndex = [...name].reduce((total, character) => total + character.charCodeAt(0), 0) % cardColors.length;
const cardBackground = cardColors[colorIndex];
---

<figure class="card" style={`--card-bg: ${cardBackground};`}>
  <img src={image} alt={name} loading="lazy" />
  <div class="card-content">
    <figcaption class="card-name">
      <a href={`/${slug}`}><span class="card-emoji">{favorite_emoji}</span> {name}</a>
    </figcaption>
    <nav class="card-links">
      <a href={github_permalink} target="_blank" rel="noopener">Portfolio</a>
      <a href={github_profile} target="_blank" rel="noopener">GitHub</a>
      <a href={codepen_profile} target="_blank" rel="noopener">CodePen</a>
    </nav>
  </div>
</figure>



<style>
  .card {
    background: var(--card-bg);
    border: 0;
    display: flex;
    flex-direction: row;
    gap: 0;
    border: 1px solid lightgray;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .card img {
    width: 50%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    clip-path: polygon(0 0, calc(100% - 2rem) 0, 100% 50%, calc(100% - 2rem) 100%, 0 100%);
  }

  figcaption.card-name {
    font-size: 2.5rem;
    font-weight: bold;
    color: white;
    text-decoration: none;
    margin: 0;
  }

  .card-name a {
    color: inherit;
    text-decoration: none;
  }

.card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
  padding: 0.5rem 1rem 0.5rem 1.5rem;
  }

  .card-emoji {
  }

  .card-links {
    font-size: 1rem;
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .card-links a {
    text-decoration: none;
    color: goldenrod;
    border-bottom: 1px solid currentColor;
    gap: 0.25rem;
    border: 1px solid goldenrod;
    border-radius: 5px;
    padding: 0.25rem 0.5rem;
  }

  .card-links a:hover {
    background: gray;
    color: white;
  }
</style>
