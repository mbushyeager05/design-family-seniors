---
import BaseLayout from "../layouts/BaseLayout.astro";
import StudentCard from "../components/StudentCard.astro";
import data from "../data/data.json";

// data object
const { students } = data;
// variables
const title = 'DESN FMLY Seniors 2026'

---

<BaseLayout title={title}>
  
  <h1> {title} </h1>
  
  <main>

    {students.map((student) => (
      <StudentCard {...student} />
    ))}
  
</main>



</BaseLayout>

<style>
  h1 {
    font-size: 5rem;
    font-weight: bold;
    color: #10212b;
    text-align: center;
    margin-bottom: 2rem;
  }   

  </style>

